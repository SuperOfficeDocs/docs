{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "aspen",
  "name": "SuperOffice",
  "colors": {
    "primary": "#06423E",
    "light": "#0F5C57",
    "dark": "#B2C7EB"
  },
  "appearance": {
    "default": "light"
  },
  "background": {
    "color": {
      "light": "#F2EFEA",
      "dark": "#1C1C1E"
    }
  },
  "fonts": {
    "heading": {
      "family": "SuperOfficeSans Bold",
      "source": "https://mintlify-assets.b-cdn.net/fonts/SuperOfficeSans-Bold.woff2",
      "format": "woff2",
      "weight": 700
    },
    "body": {
      "family": "SuperOffice Sans",
      "source": "https://mintlify-assets.b-cdn.net/fonts/SuperOfficeSans-Regular.woff2",
      "format": "woff2",
      "weight": 400
    }
  },
  "icons": {
    "library": "fontawesome"
  },
  "favicon": "/favicon.ico",
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "metadata": {
    "timestamp": false
  },
  "api": {
    "playground": {
      "display": "none"
    },
    "examples": {
      "languages": [
        "csharp",
        "javascript",
        "php",
        "python"
      ],
      "defaults": "required"
    }
  },
  "navigation": {
    "$ref": "./config/navigation.json"
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://www.superoffice.com"
  },
  "navbar": {
    "links": []
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "youtube": "https://www.youtube.com/user/SuperOfficeNetwork",
      "facebook": "https://www.facebook.com/SuperOfficeCRM",
      "x": "https://x.com/SuperOffice",
      "instagram": "https://www.instagram.com/superofficecrm",
      "linkedin": "https://www.linkedin.com/company/superoffice-as"
    },
    "links": [
      {
        "items": [
          {
            "label": "Community",
            "href": "https://community.superoffice.com"
          },
          {
            "label": "Privacy",
            "href": "https://www.superoffice.com/company/privacy/"
          }
        ]
      },
      {
        "items": [
          {
            "label": "Site feedback",
            "href": "https://github.com/SuperOfficeDocs/feedback/issues/new?title=Feedback-@Source%3A%20%5Bdocs.superoffice.com%5D(https%3A%2F%2Fdocs.superoffice.com)"
          },
          {
            "label": "Contribute",
            "href": "/contribute/"
          }
        ]
      }
    ]
  },
  "redirects": {
    "$ref": "./config/redirects.json"
  }
}