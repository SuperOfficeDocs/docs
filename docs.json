{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "aspen",
  "name": "SuperOffice",
  "colors": {
    "primary": "#06423E",
    "light": "#0F5C57",
    "dark": "#B2C7EB"
  },
  "appearance": {
    "default": "light"
  },
  "background": {
    "color": {
      "light": "#F2EFEA",
      "dark": "#1C1C1E"
    }
  },
  "fonts": {
    "heading": {
      "family": "SuperOfficeSans Bold",
      "source": "https://mintlify-assets.b-cdn.net/fonts/SuperOfficeSans-Bold.woff2",
      "format": "woff2",
      "weight": 700
    },
    "body": {
      "family": "SuperOffice Sans",
      "source": "https://mintlify-assets.b-cdn.net/fonts/SuperOfficeSans-Regular.woff2",
      "format": "woff2",
      "weight": 400
    }
  },
  "icons": {
    "library": "fontawesome"
  },
  "favicon": "/favicon.ico",
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "metadata": {
    "timestamp": false
  },
  "api": {
    "playground": {
      "display": "none"
    },
    "examples": {
      "languages": [
        "csharp",
        "javascript",
        "php",
        "python"
      ],
      "defaults": "required"
    }
  },
