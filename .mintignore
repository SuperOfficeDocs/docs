# Exclude draft documents
drafts/
*.draft.mdx

# Exclude internal documentation
internal/

# Exclude docfx assets
**/toc.yml
**/index.yml

# Exclude all API source files (used for generation)
api-sources/

# Exclude transformation scripts
tools/
transform-*.ps1

# Exclude specific files
private-notes.md
bergfrid-tmp/
release-notes/poc
redirects.json

# Exclude selected content folders to keep mint dev below 5000 pages
